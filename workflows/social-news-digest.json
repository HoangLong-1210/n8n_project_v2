    {
      "id": "a1000000-0000-4000-8000-000000000005",
      "name": "Merge Feeds",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [448, 304],
      "parameters": {
        "mode": "append",
        "numberInputs": 3
      }
    },
    {
      "id": "a1000000-0000-4000-8000-000000000006",
      "name": "Build Digest",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [672, 304],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Khử trùng lặp, sắp xếp theo thời gian, lấy 10 tin mới nhất rồi ghép thành digest\nconst seen = new Set();\nconst articles = [];\nfor (const item of $input.all()) {\n  const a = item.json;\n  const key = (a.link || a.title || '').trim();\n  if (!key || !a.title || seen.has(key)) continue; // bỏ item lỗi từ feed hỏng\n  seen.add(key);\n  articles.push({\n    title: String(a.title).trim(),\n    snippet: String(a.contentSnippet || a.content || '')\n      .replace(/<[^>]*>/g, ' ')\n      .replace(/\\s+/g, ' ')\n      .trim()\n      .slice(0, 200),\n    link: a.link || '',\n    date: a.isoDate || a.pubDate || ''\n  });\n}\narticles.sort((x, y) => new Date(y.date) - new Date(x.date));\nconst top = articles.slice(0, 10);\nif (top.length === 0) {\n  throw new Error('Không lấy được tin nào từ cả 3 nguồn RSS');\n}\nconst digest = top\n  .map((a, i) => `${i + 1}. ${a.title}\\n${a.snippet}`)\n  .join('\\n\\n');\nreturn [{ json: { digest, articleCount: top.length, links: top.map(a => a.link).join('\\n') } }];"
      }
    },
    {
      "id": "a1000000-0000-4000-8000-000000000007",
      "name": "Write Social Post",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [896, 304],
      "parameters": {
        "promptType": "define",
        "text": "=Bạn là chuyên gia viết content mạng xã hội tiếng Việt. Dưới đây là {{ $json.articleCount }} tin nóng nhất hôm nay ({{ $now.toFormat('dd/MM/yyyy') }}) tổng hợp từ VnExpress, Tuổi Trẻ, Thanh Niên:\n\n{{ $json.digest }}\n\nNhiệm vụ: viết MỘT bài đăng mạng xã hội (Facebook/Threads) dạng \"điểm tin nóng trong ngày\":\n- Mở đầu bằng 1 câu hook thu hút\n- Chọn 3-5 tin đáng chú ý nhất, mỗi tin 1-2 câu, mỗi tin một dòng bắt đầu bằng emoji phù hợp\n- Kết bài bằng 1 câu kêu gọi tương tác (hỏi ý kiến người đọc)\n- Cuối bài thêm 5-7 hashtag tiếng Việt liên quan\n- Tổng độ dài 150-250 từ, giọng gần gũi tự nhiên\n- TUYỆT ĐỐI không bịa thêm thông tin ngoài các tin ở trên\n\nChỉ trả về nội dung bài đăng hoàn chỉnh, không giải thích gì thêm."
      }
    },
    {
      "id": "a1000000-0000-4000-8000-000000000008",
      "name": "Gemini Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1.1,
      "position": [976, 528],
      "parameters": {
        "modelName": "models/gemini-2.5-flash",
        "options": { "temperature": 0.7, "maxOutputTokens": 1024 }
