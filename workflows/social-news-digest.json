      "id": "a1000000-0000-4000-8000-000000000005",
      "name": "Merge Feeds",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        448,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "// Khử trùng lặp + CÂN BẰNG NGUỒN: mỗi báo lấy tối đa 4 tin mới nhất\n// (nếu lấy \"10 tin mới nhất toàn cục\" thì báo đăng dày đặc sẽ chiếm hết digest)\n// Lưu ý: sandbox task runner không có new URL — nhận diện nguồn bằng chuỗi link\nconst seen = new Set();\nconst articles = [];\nfor (const item of $input.all()) {\n  const a = item.json;\n  const key = (a.link || a.title || '').trim();\n  if (!key || !a.title || seen.has(key)) continue; // bỏ item lỗi từ feed hỏng\n  seen.add(key);\n  const l = String(a.link || '');\n  let source = 'Khác';\n  if (l.indexOf('vnexpress') !== -1) source = 'VnExpress';\n  else if (l.indexOf('tuoitre') !== -1) source = 'Tuổi Trẻ';\n  else if (l.indexOf('thanhnien') !== -1) source = 'Thanh Niên';\n  const t = new Date(a.isoDate || a.pubDate || 0).getTime();\n  articles.push({\n    title: String(a.title).trim(),\n    snippet: String(a.contentSnippet || a.content || '')\n      .replace(/<[^>]*>/g, ' ')\n      .replace(/\\s+/g, ' ')\n      .trim()\n      .slice(0, 200),\n    link: l,\n    ts: isNaN(t) ? 0 : t,\n    source\n  });\n}\nconst bySource = {};\nfor (const a of articles) (bySource[a.source] = bySource[a.source] || []).push(a);\nconst top = [];\nfor (const list of Object.values(bySource)) {\n  list.sort((x, y) => y.ts - x.ts);\n  top.push(...list.slice(0, 4));\n}\ntop.sort((x, y) => y.ts - x.ts);\nif (top.length === 0) {\n  throw new Error('Không lấy được tin nào từ cả 3 nguồn RSS');\n}\n// đề phòng lỗi nhận diện nguồn khiến mọi tin dồn vào 1 nhóm\nconst sourceCount = Object.keys(bySource).length;\nconst digest = top\n  .map((a, i) => `${i + 1}. [${a.source}] ${a.title}\\n${a.snippet}`)\n  .join('\\n\\n');\nreturn [{ json: { digest, articleCount: top.length, sourceCount, links: top.map(a => a.link).join('\\n') } }];"
      },
