{
  "name": "[Admin] Self-Service Signup",
  "nodes": [
    {
      "id": "b2000000-0000-4000-8000-000000000001",
      "name": "Form Đăng Ký",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 2.2,
      "position": [0, 0],
      "webhookId": "c7f1a2b3-1111-4222-8333-944455556666",
      "parameters": {
        "formTitle": "Đăng ký tài khoản n8n",
        "formDescription": "Điền thông tin bên dưới. Mật khẩu tối thiểu 8 ký tự, có ít nhất 1 số và 1 chữ in hoa. Đăng ký xong bạn sẽ được chuyển đến trang đăng nhập.",
        "formFields": {
          "values": [
            { "fieldLabel": "Email", "fieldType": "email", "requiredField": true },
            { "fieldLabel": "Họ tên", "requiredField": true },
            { "fieldLabel": "Mật khẩu", "fieldType": "password", "requiredField": true }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "b2000000-0000-4000-8000-000000000003",
      "name": "Tạo User",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [224, 0],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/api/v1/users",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ [ { email: $json.Email, role: 'global:member' } ] }}",
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "UiLpnO6cy5w4X1qI",
          "name": "n8n Admin API (self-signup)"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "b2000000-0000-4000-8000-000000000007",
      "name": "Tạo OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [448, 0],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.user ? $json.user.id : '' }}",
              "operator": { "type": "string", "operation": "notEmpty", "singleValue": true },
              "rightValue": ""
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "b2000000-0000-4000-8000-000000000008",
      "name": "Kích Hoạt Tài Khoản",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [672, -96],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/rest/invitations/accept",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { token: $json.user.inviteAcceptUrl.split('token=')[1], firstName: (($('Form Đăng Ký').item.json['Họ tên'] || '').trim().split(/\\s+/).slice(1).join(' ')) || ($('Form Đăng Ký').item.json['Họ tên'] || '').trim(), lastName: (($('Form Đăng Ký').item.json['Họ tên'] || '').trim().split(/\\s+/)[0]) || 'User', password: $('Form Đăng Ký').item.json['Mật khẩu'] } }}",
        "options": {}
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "b2000000-0000-4000-8000-000000000009",
      "name": "Kích Hoạt OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [896, -96],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "leftValue": "={{ ($json.data && $json.data.id) || $json.id || '' }}",
              "operator": { "type": "string", "operation": "notEmpty", "singleValue": true },
              "rightValue": ""
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "b2000000-0000-4000-8000-00000000000a",
      "name": "Về Trang Đăng Nhập",
      "type": "n8n-nodes-base.form",
      "typeVersion": 1,
      "position": [1120, -192],
      "webhookId": "c7f1a2b3-1111-4222-8333-944455557777",
      "parameters": {
        "operation": "completion",
        "respondWith": "redirect",
        "redirectUrl": "https://n8n.n8nagent.website/signin",
        "options": {}
      }
    },
    {
      "id": "b2000000-0000-4000-8000-00000000000b",
      "name": "Dọn User Hỏng",
