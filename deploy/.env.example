# ==========================================================
# Copy file này thành .env rồi điền giá trị thật:
#     cp .env.example .env
# KHÔNG commit file .env (NFR-3)
# ==========================================================

# Domain trỏ về IP server (bản ghi DNS A) — P-1 trong BRD
# Ví dụ: n8n.tenmiencuaban.com
N8N_HOST=n8n.example.com

# --- PostgreSQL ---
POSTGRES_USER=n8n
POSTGRES_DB=n8n
# Sinh mật khẩu mạnh:  openssl rand -base64 24
POSTGRES_PASSWORD=DOI_MAT_KHAU_NAY

# --- n8n ---
# Khóa mã hóa credentials — SINH MỘT LẦN, LƯU CẨN THẬN, MẤT LÀ MẤT HẾT CREDENTIALS
# Sinh bằng:  openssl rand -hex 32
N8N_ENCRYPTION_KEY=DOI_KHOA_NAY
